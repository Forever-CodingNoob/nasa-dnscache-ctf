[Unit]
Description=Service to keep benign-forwarder.py online
After=network.target

[Service]
Type=simple
WorkingDirectory=/path/to/this/dir/
ExecStart=/bin/bash -c 'source ./venv/bin/activate && ./benign-forwarder.py'
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
